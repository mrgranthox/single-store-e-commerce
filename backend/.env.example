NODE_ENV=development
PORT=4000

# In NODE_ENV=production, APP_BASE_URL / ADMIN_APP_URL / CUSTOMER_APP_URL / MOBILE_APP_URL must be non-loopback HTTPS URLs,
# CORS_ALLOWED_ORIGINS must not match the default local dev list below, DATABASE_URL/REDIS_URL must not use localhost,
# and EMAIL_FROM must not use example.com when EMAIL_PROVIDER=brevo (see src/config/env.ts).
APP_BASE_URL=http://localhost:4000
# Admin SPA (Vite) defaults to port 5174 — see admin-frontend/vite.config.js
ADMIN_APP_URL=http://localhost:5174
CUSTOMER_APP_URL=http://localhost:3001
MOBILE_APP_URL=http://localhost:3002
# Include localhost + 127.0.0.1 for Vite; browsers send Origin as one or the other
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:5174,http://127.0.0.1:5174

DATABASE_URL=postgresql://ecommerce_user:strongpassword@localhost:5432/ecommerce_db
REDIS_URL=redis://localhost:6379
WORKER_HEARTBEAT_INTERVAL_SECONDS=15
WORKER_HEARTBEAT_TTL_SECONDS=45
QUEUE_PREFIX=ecommerce

CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILE_SAMPLE_RATE=0
SENTRY_ATTACH_STACKTRACE=true
SENTRY_SEND_DEFAULT_PII=false
SENTRY_DEBUG=false

PAYMENT_PROVIDER=paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_API_BASE_URL=https://api.paystack.co
PAYSTACK_REQUEST_TIMEOUT_MS=10000
PAYSTACK_ALLOWED_CHANNELS=card,mobile_money
PAYSTACK_ALLOWED_WEBHOOK_IPS=52.31.139.75,52.49.173.169,52.214.14.220
PAYSTACK_ALLOWED_MOBILE_MONEY_PROVIDERS=mtn,tgo,vod
PAYSTACK_DEFAULT_CURRENCY=GHS
PAYSTACK_CALLBACK_URL=http://localhost:3001/checkout/payment/result
PAYSTACK_VERIFY_TRANSACTIONS=true

# brevo | none — production with "brevo" requires SMTP or Brevo API credentials (see env.ts).
EMAIL_PROVIDER=brevo
BREVO_SMTP_HOST=smtp-relay.brevo.com
# Legacy alias still accepted: BREVO_SMTP_SERVER=
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=
BREVO_SMTP_PASSWORD=
BREVO_SMTP_CONNECTION_TIMEOUT_MS=10000
BREVO_SMTP_GREETING_TIMEOUT_MS=10000
BREVO_SMTP_SOCKET_TIMEOUT_MS=15000
BREVO_API_KEY=
BREVO_API_BASE_URL=https://api.brevo.com/v3
BREVO_API_TIMEOUT_MS=10000
EMAIL_FROM=no-reply@example.com
EMAIL_FROM_NAME=E-Commerce Platform
EMAIL_REPLY_TO=support@example.com

# cloudinary | none — production with "cloudinary" requires CLOUDINARY_* trio (see env.ts).
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=ecommerce
# Legacy alias still accepted: CLOUDINARY_FOLDER_NAME=
CLOUDINARY_PRODUCT_MEDIA_FOLDER=catalog/products
CLOUDINARY_BANNER_FOLDER=content/banners
CLOUDINARY_SUPPORT_FOLDER=support/attachments
CLOUDINARY_SIGNED_UPLOADS_ONLY=true
CLOUDINARY_ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp,avif
CLOUDINARY_ALLOWED_VIDEO_FORMATS=mp4,mov,webm
CLOUDINARY_ALLOWED_DOCUMENT_FORMATS=pdf,jpg,jpeg,png,webp
CLOUDINARY_MAX_IMAGE_BYTES=8388608
CLOUDINARY_MAX_VIDEO_BYTES=52428800
CLOUDINARY_MAX_DOCUMENT_BYTES=12582912

ABUSE_CHALLENGE_PROVIDER=none
PUBLIC_SUPPORT_CAPTCHA_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_EXPECTED_HOSTNAMES=localhost
TURNSTILE_ENFORCE_ACTION=true
TURNSTILE_TIMEOUT_MS=5000

# Minimum 32 characters (enforced by env schema)
SESSION_SECRET=development-session-secret-min-32-chars!!
LOG_LEVEL=debug
ALLOW_DEV_AUTH_BYPASS=true
ADMIN_API_ACCESS_TOKEN_TTL_MINUTES=10
ADMIN_API_REFRESH_TOKEN_TTL_DAYS=3
ADMIN_STEP_UP_TTL_MINUTES=10
ADMIN_REQUIRE_STEP_UP_FOR_SENSITIVE_ACTIONS=true
ADMIN_SESSION_ANOMALY_DETECTION_ENABLED=true
DEPLOYMENT_CELL=local
APP_RELEASE_LABEL=local-dev

# Optional: after `npm run seed` (roles/permissions), links a DB admin row to your Clerk user for /api/admin/auth/login.
# Option A — password (dev/staging only; not allowed in production): creates or updates the Clerk user and sets password.
# If your Clerk instance requires a phone number on signup, set E.164 (e.g. +12015550123).
# SEED_DEFAULT_ADMIN_PASSWORD=choose-a-strong-password
# SEED_DEFAULT_ADMIN_PHONE=
# Option B — existing Clerk user: set email + Clerk user id (user_...).
# SEED_DEFAULT_ADMIN_CLERK_USER_ID=
SEED_DEFAULT_ADMIN_EMAIL=
SEED_DEFAULT_ADMIN_CLERK_USER_ID=
SEED_DEFAULT_ADMIN_PASSWORD=
SEED_DEFAULT_ADMIN_ROLE=super_admin
